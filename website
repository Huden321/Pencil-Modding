import { motion } from "framer-motion";
import { Camera, Heart, MessageCircle, Trophy, Upload, User, Star, Pencil, Flame, Search, PlusCircle } from "lucide-react";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar";
import { Badge } from "@/components/ui/badge";

const starterProfiles = [
  {
    id: 1,
    name: "GraphiteGhost",
    description: "I build clean, balanced pencil mods with metal grips and custom clips.",
    profilePic: "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=400&auto=format&fit=crop&q=60",
  },
  {
